# ── Ollama (local LLM fallback) ────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llava:7b

# ── App ────────────────────────────────────────────────────────────────────
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
DEBUG=true
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
