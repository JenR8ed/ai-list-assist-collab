# ── Google AI ──────────────────────────────────────────────────────────────
GOOGLE_API_KEY=
GOOGLE_CLOUD_PROJECT=
VERTEX_AI_LOCATION=us-central1

# ── eBay API ───────────────────────────────────────────────────────────────
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_USER_TOKEN=
EBAY_SANDBOX=true

# ── Telegram Bot ───────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
