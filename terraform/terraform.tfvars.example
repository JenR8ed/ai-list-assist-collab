# Copy this file to "terraform.tfvars" and replace the placeholders with your actual GCP details

org_id          = "YOUR_ORG_ID"
billing_account = "YOUR_BILLING_ACCOUNT_ID"

project_name    = "ai-list-assist-collab"

# Optional: If you want to place the project in a specific folder
# folder_id       = "YOUR_FOLDER_ID"

# Optional: Default is us-central1
# region          = "us-central1"
